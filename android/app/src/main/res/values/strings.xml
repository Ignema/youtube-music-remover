    <string name="help_paste_link">Paste a YouTube link</string>
    <string name="help_paste_desc">Copy a URL from YouTube and paste it in the input field. You can also share directly from the YouTube app.</string>
    <string name="help_tap_remove">Tap Remove Music</string>
    <string name="help_tap_remove_desc">The app will download the video, separate the vocals using AI, and merge everything back together.</string>
    <string name="help_play_save">Play or save</string>
    <string name="help_play_save_desc">Once done, play the result directly or save it anywhere on your device.</string>
    <string name="help_pick_file">Pick a video file</string>
    <string name="help_pick_file_desc">Instead of a YouTube link, tap "Pick a video file" to select a video from your device.</string>
    <string name="help_process_usual">Process as usual</string>
    <string name="help_process_usual_desc">The app uploads the file to the server, extracts audio, separates vocals, and returns the result.</string>
    <string name="help_tap_share">Tap Share in YouTube</string>
    <string name="help_tap_share_desc">Open any video in the YouTube app and tap the Share button.</string>
    <string name="help_pick_murem">Pick Murem</string>
    <string name="help_pick_murem_desc">Select Murem from the share sheet. The URL will be filled in automatically.</string>
    <string name="help_local_termux">Local (Termux)</string>
    <string name="help_local_termux_desc">Process on your phone. Install Termux from F-Droid, then go to Settings → tap Install → Start. Slower but fully offline.</string>
    <string name="help_remote_server">Remote server</string>
    <string name="help_remote_server_desc">Run the server on a PC with a GPU for much faster processing. Set the URL in Settings → Custom.</string>
    <string name="help_start_pc">Start the server on PC</string>
    <string name="help_start_pc_desc">Clone the repo first:\ngit clone https://github.com/Ignema/youtube-music-remover.git\ncd youtube-music-remover\n\nThen start the server:\nuvx --with fastapi --with yt-dlp --with \"audio-separator[gpu]\" uvicorn api.main:app --host 0.0.0.0 --port 8000</string>
    <string name="help_docker">Docker (easiest for PC)</string>
    <string name="help_docker_desc">docker build -t murem api/\ndocker run -p 8000:8000 murem\n\nThat\'s it — no Python or ffmpeg setup needed.</string>

