<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:paddingHorizontal="12dp"
    android:paddingVertical="4dp"
    android:background="@drawable/widget_background"
    android:gravity="center_vertical">

    <!-- Logo — tap to open app -->
    <ImageView
        android:id="@+id/widget_logo"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_launcher_foreground"
        android:scaleType="centerInside"
        android:contentDescription="@string/app_name" />

    <!-- Action buttons -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginStart="4dp">

        <!-- Paste & Process -->
        <LinearLayout
            android:id="@+id/widget_paste_process"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?android:attr/selectableItemBackgroundBorderless">
            <ImageView
                android:layout_width="20dp"`n                android:layout_height="20dp"
                android:src="@drawable/ic_widget_paste"
                android:scaleType="centerInside"
                android:importantForAccessibility="no" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tab_url"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:layout_marginTop="1dp" />
        </LinearLayout>

        <!-- File Upload -->
        <LinearLayout
            android:id="@+id/widget_file"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?android:attr/selectableItemBackgroundBorderless">
            <ImageView
                android:layout_width="20dp"`n                android:layout_height="20dp"
                android:src="@drawable/ic_widget_upload"
                android:scaleType="centerInside"
                android:importantForAccessibility="no" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tab_file"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:layout_marginTop="1dp" />
        </LinearLayout>

        <!-- Batch -->
        <LinearLayout
            android:id="@+id/widget_batch"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?android:attr/selectableItemBackgroundBorderless">
            <ImageView
                android:layout_width="20dp"`n                android:layout_height="20dp"
                android:src="@drawable/ic_widget_batch"
                android:scaleType="centerInside"
                android:importantForAccessibility="no" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tab_batch"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:layout_marginTop="1dp" />
        </LinearLayout>

        <!-- Settings -->
        <LinearLayout
            android:id="@+id/widget_settings"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?android:attr/selectableItemBackgroundBorderless">
            <ImageView
                android:layout_width="20dp"`n                android:layout_height="20dp"
                android:src="@drawable/ic_widget_settings"
                android:scaleType="centerInside"
                android:importantForAccessibility="no" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:layout_marginTop="1dp" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>

